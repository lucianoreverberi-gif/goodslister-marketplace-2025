# Goodslister Environment Variables Example
# Copy this file to .env and fill in the values

# --- Gemini API ---
# Get your key at https://aistudio.google.com/
GEMINI_API_KEY=

# --- Vercel Postgres (Database) ---
# These are automatically populated when you connect a Postgres store in Vercel
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# --- Vercel Blob (Image Storage) ---
# Automatically populated when you connect a Blob store in Vercel
BLOB_READ_WRITE_TOKEN=

# --- Resend (Email Service) ---
# Get your key at https://resend.com/
RESEND_API_KEY=

# --- Stripe (Payments) ---
# Get your keys at https://dashboard.stripe.com/test/apikeys
STRIPE_ENABLED=false
NEXT_PUBLIC_STRIPE_ENABLED=false
VITE_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_LOCAL=
STRIPE_PRICE_ID_SPOTLIGHT=
STRIPE_PRICE_ID_REGIONAL=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Cron Jobs ---
# Secret for protecting cron endpoints
CRON_SECRET=

# --- Twilio (SMS & Verification) ---
# Get your credentials at https://www.twilio.com/console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- App Configuration ---
# The URL of your deployed application
VITE_APP_URL=

# --- Admin Operations and Migrations ---
# Secure secret for running admin tasks (must be configured on Vercel)
ADMIN_MIGRATION_SECRET=
