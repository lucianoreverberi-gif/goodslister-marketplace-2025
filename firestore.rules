rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net - Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isAdmin() { 
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['SUPER_ADMIN', 'REGION_MANAGER']
      );
    }

    // --- Collections ---
    
    // Auth Check Bypass for Demo:
    // To support mock users like "Carlos Gomez" who use custom login, 
    // we allow reading/creation of conversations/messages without forced request.auth
    
    match /test/connection {
      allow read: if true;
    }

    match /users/{userId} {
      allow read: if true; 
      allow write: if true; // In production: if isOwner(userId) || isAdmin()
    }

    match /listings/{listingId} {
      allow read: if true;
      allow write: if true; // In production: if isSignedIn()
    }

    match /bookings/{bookingId} {
      allow read, write: if true; // In production: if isSignedIn()
    }

    match /conversations/{conversationId} {
      // In a production app, we would strictly require request.auth.uid to be in participants.
      // For this demo/prototype, we allow read/write access to enable cross-session chat 
      // for mock users who don't have a Firebase account yet.
      allow read, write: if true; 
      
      match /messages/{messageId} {
        allow read, write: if true;
      }
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if true;
    }
  }
}
