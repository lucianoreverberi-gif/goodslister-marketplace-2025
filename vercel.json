{
    "rewrites": [
          {
                  "source": "/api/(.*)",
                  "destination": "/api/$1"
          },
          {
                  "source": "/(.*)",
                  "destination": "/index.html"
          }
    ],
    "crons": [
          {
                  "path": "/api/cron/pickup-reminder",
                  "schedule": "0 8 * * *"
          }
    ]
}
